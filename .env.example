# ---- Portfolio CMS env ----
# Локально (SQLite): достаточно DATABASE_URI + PAYLOAD_SECRET + NEXT_PUBLIC_SERVER_URL.
# Прод (Vercel): задать POSTGRES_URL (Neon) + BLOB_READ_WRITE_TOKEN + PAYLOAD_SECRET + NEXT_PUBLIC_SERVER_URL.

# --- Локальная БД (SQLite). Игнорируется, если задан POSTGRES_URL. ---
DATABASE_URI=file:./portfolio.db

# --- Прод БД (Neon Postgres, pooled connection string). ---
# Подключается через интеграцию Neon в Vercel (переменная появится автоматически).
# POSTGRES_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require

# --- Секрет Payload (обязателен везде). Сгенерировать: openssl rand -hex 32 ---
PAYLOAD_SECRET=

# --- Публичный URL сервера. Локально http://localhost:3001, в проде — домен Vercel. ---
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# --- Vercel Blob (хранилище медиа в проде). Появится через интеграцию Blob в Vercel. ---
# BLOB_READ_WRITE_TOKEN=

# --- Сид первого админа (используется один раз при пустой БД). ---
SEED_ADMIN_LOGIN=admin
SEED_ADMIN_PASSWORD=change-me

# --- Секрет для защиты /seed и /importmap в проде (?secret=...). ---
SEED_SECRET=
